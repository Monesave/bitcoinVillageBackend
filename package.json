{
  "name": "@bitcoinvillagex/backend",
  "version": "1.0.0",
  "description": "Backend API server for BitcoinVillageX",
  "main": "dist/server.js",
  "scripts": {
    "dev": " tsx watch src/server.ts",
    "build": "tsc --skipLibCheck || true",
    "start": "tsx src/server.ts",
    "start:compiled": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bitcoinvillagex/shared": "file:../shared",
    "@supabase/server": "^1.3.0",
    "@supabase/supabase-js": "^2.38.5",
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.1.11",
    "tsx": "^4.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3"
  }
}
